---

---

<section
  id="hero-section"
  class="relative w-full min-h-screen flex flex-col justify-end bg-[#0a0a0a] overflow-hidden"
>
  <!-- Subtle grain texture overlay -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: url(\"
    data:image
    svg+xml,%3Csvg
    viewBox="0 0 512 512"
    xmlns="http://www.w3.org/2000/svg"
    %3E%3Cfilter
    id="noise"
    %3E%3CfeTurbulence
    type="fractalNoise"
    baseFrequency="0.9"
    numOctaves="4"
    stitchTiles="stitch"
    %3E%3C
    filter%3E%3Crect
    width="100%25"
    height="100%25"
    filter="url(%23noise)"
    %3E%3C
    svg%3E\");
    background-size:
    200px;"
  >
  </div>

  <!-- Accent line — top right geometric -->
  <div class="absolute top-0 right-0 w-[1px] h-full bg-[#c8a96e] opacity-20">
  </div>

  <!-- Large background text — architectural -->
  <div
    class="absolute bottom-0 right-0 leading-none select-none pointer-events-none overflow-hidden"
    style="font-family:'Manrope',sans-serif; font-weight:800; font-size:clamp(180px,22vw,320px); letter-spacing:-0.06em; color:transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.04); line-height:0.85;"
  >
    UV
  </div>

  <!-- Main content -->
  <div
    class="relative max-w-[1400px] mx-auto px-6 lg:px-10 w-full pb-20 sm:pb-28"
  >
    <!-- Overline with year -->
    <div class="flex items-center gap-4 mb-12">
      <div class="w-8 h-px bg-[#c8a96e]"></div>
      <span class="overline text-white/30">Fundada 2019 · Chile</span>
    </div>

    <!-- Hero headline — mixed serif/sans editorial -->
    <div class="max-w-[900px] mb-10">
      <h1 class="text-white">
        <span
          class="block font-display italic text-[clamp(2.8rem,7vw,6.5rem)] leading-[0.95] font-normal mb-3"
          >Conectamos</span
        >
        <span
          class="block font-bold text-[clamp(2.4rem,6.5vw,6rem)] leading-[0.95] tracking-tight"
          >empresas con los<br />proveedores que necesitan.</span
        >
      </h1>
    </div>

    <!-- Bottom bar: description + CTA -->
    <div
      class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 pt-8 border-t border-white/10"
    >
      <p
        class="text-[15px] text-white/40 max-w-[380px] font-light leading-relaxed"
      >
        Representación y gestión comercial en los sectores industrial, agrícola
        y de seguridad en Chile.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="#about"
          class="text-[11px] font-semibold tracking-[0.2em] uppercase text-white/30 hover:text-white transition-colors"
        >
          Explorar ↓
        </a>
        <a
          href="#contact"
          class="text-[11px] font-semibold tracking-[0.2em] uppercase text-white border border-white/20 hover:border-[#c8a96e] hover:text-[#c8a96e] px-6 py-3 transition-all duration-300"
        >
          Iniciar Contacto
        </a>
      </div>
    </div>
  </div>
</section>
