---
const metrics = [
  {
    value: 300,
    suffix: "+",
    label: "Clientes atendidos",
    note: "Empresas y pymes",
  },
  {
    value: 5,
    suffix: "+",
    label: "Años de experiencia",
    note: "En el mercado",
  },
  {
    value: 4,
    suffix: "",
    label: "Sectores estratégicos",
    note: "Industrial, agrícola, seguridad y gestión",
  },
  { value: 300, suffix: "+", label: "Proyectos ejecutados", note: "Con éxito" },
];
---

<section class="light-section bg-[#f5f2ec] py-0">
  <!-- Full-width grid with borders -->
  <div class="grid grid-cols-2 md:grid-cols-4 border-b border-[#e0dbd0]">
    {
      metrics.map((item, i) => (
        <div
          class={`px-8 py-10 ${i < 3 ? "border-r border-[#e0dbd0]" : ""} reveal reveal-delay-${i + 1}`}
        >
          <p class="text-[11px] font-semibold tracking-widest uppercase text-neutral-400 mb-4">
            {item.note}
          </p>
          <p class="text-[2.8rem] sm:text-[3.5rem] font-extrabold tracking-tight text-[#0a0a0a] leading-none">
            <span data-target={item.value} data-suffix={item.suffix}>
              0
            </span>
          </p>
          <p class="text-[13px] text-neutral-500 mt-2 font-medium">
            {item.label}
          </p>
        </div>
      ))
    }
  </div>
</section>
