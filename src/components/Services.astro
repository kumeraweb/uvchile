---
const services = [
  {
    number: "01",
    title: "Industrial",
    detail:
      "Embalaje, logística, EPP, ropa corporativa y soluciones esenciales para operaciones industriales de gran escala.",
    tag: "Manufactura & Logística",
  },
  {
    number: "02",
    title: "Seguridad & Defensa",
    detail:
      "Equipamiento balístico, blindajes y servicios de seguridad operativa para empresas, instituciones y organismos gubernamentales.",
    tag: "Protección & Escolta",
  },
  {
    number: "03",
    title: "Agrícola",
    detail:
      "Agroquímicos, fertizantes y ferretería agrícola para potenciar la productividad y eficiencia del sector agroindustrial.",
    tag: "Agroindustria",
  },
  {
    number: "04",
    title: "Gestión Integral",
    detail:
      "Resolvemos múltiples necesidades simultáneas actuando como un único punto estratégico de solución para su empresa.",
    tag: "Consultoría Comercial",
  },
];
---

<section id="services" class="light-section bg-[#f5f2ec] py-28 lg:py-36">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <!-- Header row -->
    <div
      class="flex flex-col sm:flex-row sm:items-end justify-between mb-0 pb-8 border-b border-[#e0dbd0]"
    >
      <div class="reveal">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-6 h-px bg-[#c8a96e]"></div>
          <span class="overline text-neutral-400">Rubros</span>
        </div>
        <h2
          class="font-heading font-bold text-[clamp(2rem,4vw,3.2rem)] text-[#0a0a0a] leading-tight tracking-tight"
        >
          Sectores en<br />los que operamos.
        </h2>
      </div>
      <p
        class="text-[13px] text-neutral-400 max-w-[260px] mt-4 sm:mt-0 reveal reveal-delay-1"
      >
        Especialización por sector para garantizar precisión en cada solución
        que entregamos.
      </p>
    </div>

    <!-- Service rows -->
    {
      services.map((service, i) => (
        <div
          class={`grid grid-cols-12 gap-4 lg:gap-0 py-10 border-b border-[#e0dbd0] group cursor-default hover:bg-white transition-colors duration-300 px-0 hover:px-4 reveal reveal-delay-${(i % 3) + 1}`}
        >
          <div class="col-span-1 text-[11px] font-mono text-neutral-300 pt-1">
            {service.number}
          </div>
          <div class="col-span-11 sm:col-span-4 lg:col-span-3">
            <p class="text-[10px] font-semibold tracking-widest uppercase text-neutral-400 mb-2">
              {service.tag}
            </p>
            <h3 class="font-heading font-bold text-[1.35rem] text-[#0a0a0a] tracking-tight group-hover:text-[#c8a96e] transition-colors duration-300">
              {service.title}
            </h3>
          </div>
          <div class="col-span-11 col-start-2 sm:col-span-6 sm:col-start-auto lg:col-span-7 lg:pl-10">
            <p class="text-[15px] text-neutral-500 leading-relaxed">
              {service.detail}
            </p>
          </div>
          <div class="col-span-1 flex items-center justify-end">
            <span class="text-neutral-200 group-hover:text-[#c8a96e] transition-colors duration-300 text-lg">
              →
            </span>
          </div>
        </div>
      ))
    }
  </div>
</section>
