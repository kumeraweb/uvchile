---
const whatsappLink = "https://wa.me/56978698975";
---

<section id="contact" class="bg-[#0a0a0a] relative overflow-hidden">
  <!-- Top gold rule -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#c8a96e] to-transparent opacity-30"
  >
  </div>

  <!-- Ghost text -->
  <div
    class="absolute top-0 right-0 leading-none select-none pointer-events-none"
    style="font-family:'Manrope',sans-serif; font-weight:800; font-size:clamp(140px,20vw,280px); letter-spacing:-0.06em; color:transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.03); line-height:0.85;"
  >
    UV
  </div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-28 lg:py-40 relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-0">
      <!-- Left: heading -->
      <div class="lg:col-span-6 lg:pr-24 reveal">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-6 h-px bg-[#c8a96e]"></div>
          <span class="overline text-white/30">Contacto</span>
        </div>
        <h2
          class="font-heading font-bold text-[clamp(2.2rem,4.5vw,3.8rem)] text-white leading-[1.05] tracking-tight mb-6"
        >
          Hablemos sobre las necesidades de su empresa.
        </h2>
        <p
          class="text-[16px] text-white/40 leading-relaxed font-light max-w-[400px]"
        >
          Acceda a nuestra red de proveedores verificados y potencie sus
          operaciones con soluciones a medida.
        </p>
      </div>

      <!-- Right: action panel -->
      <div
        class="lg:col-span-5 lg:col-start-8 lg:border-l lg:border-white/10 lg:pl-16 flex flex-col justify-center reveal reveal-delay-2"
      >
        <a
          href={whatsappLink}
          target="_blank"
          class="flex items-center justify-between w-full
                 bg-white text-[#0a0a0a] px-8 py-5 mb-4
                 hover:bg-[#c8a96e] transition-colors duration-300 group"
        >
          <div class="flex items-center gap-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 fill-[#0a0a0a] flex-shrink-0"
              viewBox="0 0 24 24"
            >
              <path
                d="M20.52 3.48A11.93 11.93 0 0 0 12 .04C5.37.04.06 5.36.06 12a11.9 11.9 0 0 0 1.64 6L0 24l6.17-1.6A11.94 11.94 0 0 0 12 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.48-8.52ZM12 22.05a9.93 9.93 0 0 1-5.06-1.38l-.36-.21-3.66.95.98-3.57-.23-.37A9.9 9.9 0 0 1 2.07 12c0-5.47 4.45-9.93 9.93-9.93 2.65 0 5.14 1.04 7.02 2.92a9.86 9.86 0 0 1 2.92 7.02c0 5.47-4.45 9.93-9.93 9.93Zm5.47-7.38c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.66.15-.2.3-.76.97-.93 1.17-.17.2-.34.22-.63.07-.3-.15-1.26-.46-2.4-1.47-.89-.79-1.5-1.77-1.68-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.34.45-.51.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.66-1.6-.9-2.2-.24-.57-.48-.5-.66-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.5 0 1.48 1.07 2.9 1.22 3.1.15.2 2.1 3.2 5.1 4.48.71.3 1.26.47 1.69.6.71.22 1.36.19 1.87.12.57-.09 1.77-.72 2.02-1.43.25-.71.25-1.32.17-1.43-.07-.12-.27-.2-.57-.35Z"
              ></path>
            </svg>
            <div>
              <p
                class="text-[11px] font-semibold tracking-widest uppercase text-neutral-500 group-hover:text-[#0a0a0a]/60"
              >
                WhatsApp
              </p>
              <p class="text-[15px] font-semibold">+56 9 7869 8975</p>
            </div>
          </div>
          <span
            class="text-neutral-300 group-hover:text-[#0a0a0a] transition-colors"
            >→</span
          >
        </a>

        <a
          href="mailto:contacto@uvchile.cl"
          class="flex items-center justify-between w-full
                 border border-white/15 text-white px-8 py-5
                 hover:border-[#c8a96e] hover:text-[#c8a96e] transition-all duration-300 group"
        >
          <div>
            <p
              class="text-[11px] font-semibold tracking-widest uppercase text-white/30 group-hover:text-[#c8a96e]/60"
            >
              Email
            </p>
            <p class="text-[15px] font-medium">contacto@uvchile.cl</p>
          </div>
          <span
            class="text-white/20 group-hover:text-[#c8a96e] transition-colors"
            >→</span
          >
        </a>
      </div>
    </div>
  </div>
</section>
